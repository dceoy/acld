#!/usr/bin/env sh
set -eu

# Create bind-mount target directories requested by `linux-desktop up
# --volume`/HOST_MOUNTS_FILE. Best-effort: paths outside what this
# non-root user can create (e.g. under a root-owned parent) must already
# exist in the image.
if [ -n "${MOUNT_TARGETS:-}" ]; then
  old_ifs=${IFS}
  IFS=':'
  # shellcheck disable=SC2086
  set -- ${MOUNT_TARGETS}
  IFS="${old_ifs}"
  for mount_target in "$@"; do
    [ -z "${mount_target}" ] && continue
    if ! mkdir -p "${mount_target}" 2>/dev/null; then
      printf 'WARNING: could not create mount target %s -- ensure it already exists and is writable\n' "${mount_target}" >&2
    fi
  done
fi

mkdir -p "${HOME}/.vnc"

printf '%s\n' "${VNC_PASSWORD}" | vncpasswd -f > "${HOME}/.vnc/passwd"
chmod 600 "${HOME}/.vnc/passwd"

cat > "${HOME}/.vnc/xstartup" <<'EOF'
#!/usr/bin/env sh
unset SESSION_MANAGER
unset DBUS_SESSION_BUS_ADDRESS
exec startxfce4
EOF
chmod +x "${HOME}/.vnc/xstartup"

vncserver "${DISPLAY}" \
  -geometry "${VNC_GEOMETRY}" \
  -depth "${VNC_DEPTH}" \
  -localhost no

exec websockify \
  --web=/usr/share/novnc \
  "0.0.0.0:${NOVNC_PORT}" \
  "localhost:5901"
