#!/usr/bin/env sh
# Compatibility wrapper around the Makefile-backed operator commands.
set -eu

SCRIPT_DIR=$(CDPATH='' cd -- "$(dirname -- "$0")" && pwd)
cd "${SCRIPT_DIR}"

MAKE_BIN=${MAKE:-make}
cmd=${1:-help}
if [ $# -gt 0 ]; then
  shift
fi

CLI_VOLUMES=${CLI_VOLUMES:-}
BUILD=${BUILD:-0}
REMOVE_IMAGE=${REMOVE_IMAGE:-0}
JSON=${JSON:-0}

append_volume() {
  CLI_VOLUMES=${CLI_VOLUMES}${CLI_VOLUMES:+"
"}$1
}

print_usage() {
  "${MAKE_BIN}" --no-print-directory help
}

run_make() {
  export CLI_VOLUMES BUILD REMOVE_IMAGE JSON
  exec "${MAKE_BIN}" --no-print-directory "$@"
}

parse_up_options() {
  while [ $# -gt 0 ]; do
    case "$1" in
      --build | --rebuild)
        BUILD=1
        ;;
      --volume)
        shift
        if [ $# -eq 0 ]; then
          echo "ERROR: --volume requires an argument" >&2
          exit 2
        fi
        append_volume "$1"
        ;;
      -h | --help)
        print_usage
        exit 0
        ;;
      *)
        echo "ERROR: unknown option for ${cmd}: $1" >&2
        exit 2
        ;;
    esac
    shift
  done
}

parse_clean_options() {
  while [ $# -gt 0 ]; do
    case "$1" in
      --image | --all)
        REMOVE_IMAGE=1
        ;;
      -h | --help)
        print_usage
        exit 0
        ;;
      *)
        echo "ERROR: unknown option for ${cmd}: $1" >&2
        exit 2
        ;;
    esac
    shift
  done
}

parse_status_options() {
  while [ $# -gt 0 ]; do
    case "$1" in
      --json)
        JSON=1
        ;;
      -h | --help)
        print_usage
        exit 0
        ;;
      *)
        echo "ERROR: unknown option for status: $1" >&2
        exit 2
        ;;
    esac
    shift
  done
}

reject_options() {
  while [ $# -gt 0 ]; do
    case "$1" in
      -h | --help)
        print_usage
        exit 0
        ;;
      *)
        echo "ERROR: unknown option for ${cmd}: $1" >&2
        exit 2
        ;;
    esac
    shift
  done
}

case "${cmd}" in
  up | restart)
    parse_up_options "$@"
    run_make "${cmd}"
    ;;
  reset)
    while [ $# -gt 0 ]; do
      case "$1" in
        --build | --rebuild)
          BUILD=1
          ;;
        --image | --all)
          REMOVE_IMAGE=1
          ;;
        --volume)
          shift
          if [ $# -eq 0 ]; then
            echo "ERROR: --volume requires an argument" >&2
            exit 2
          fi
          append_volume "$1"
          ;;
        -h | --help)
          print_usage
          exit 0
          ;;
        *)
          echo "ERROR: unknown option for reset: $1" >&2
          exit 2
          ;;
      esac
      shift
    done
    run_make reset
    ;;
  clean)
    parse_clean_options "$@"
    run_make clean
    ;;
  status)
    parse_status_options "$@"
    run_make status
    ;;
  build | down | shell | doctor)
    reject_options "$@"
    run_make "${cmd}"
    ;;
  help | -h | --help)
    print_usage
    ;;
  *)
    echo "ERROR: unknown command: ${cmd}" >&2
    print_usage >&2
    exit 2
    ;;
esac
